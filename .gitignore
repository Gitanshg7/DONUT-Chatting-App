# ========================
# Backend (Spring Boot / Maven)
# ========================

# Compiled class files
backend/target/


# IDE - Eclipse
backend/.classpath
backend/.project
backend/.settings/

# IDE - IntelliJ
backend/.idea/
backend/*.iml

# Logs
backend/*.log

# Application secrets (DO NOT COMMIT)
backend/src/main/resources/application-local.properties
# ========================
# Frontend (React / Vite / Node)
# ========================

# Dependencies
frontend/node_modules/

# Build output
frontend/dist/

# Vite cache
frontend/.vite/

# Logs
frontend/*.log
frontend/npm-debug.log*

# ========================
# OS & Editor Files
# ========================

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code
.vscode/

# Environment variables
.env
.env.local
.env.*.local

# ========================
# Sensitive / Secret Files
# ========================

# Never commit credentials or secrets
*.pem
*.key
*.p12
*.jks
